# =============================================================================
# RAG Demo Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama Configuration (Local LLM)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# HTTP port for python main.py / uvicorn (match frontend proxy.conf.js default target)
API_PORT=8010

# -----------------------------------------------------------------------------
# ChromaDB - Vector Store (local persistent storage, no server needed)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_DIR=./chroma_data

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# -----------------------------------------------------------------------------
# Knowledge Base Directory
# -----------------------------------------------------------------------------
# Point this to your app's existing docs folder to enable /index-knowledge-base endpoint
# This indexes static markdown files you've already written.
# Example: KNOWLEDGE_BASE_DIR=C:/rohit/workspace/smart_web-app/docs
KNOWLEDGE_BASE_DIR=

# -----------------------------------------------------------------------------
# Auto-Documentation Generation from Angular Source Code
# -----------------------------------------------------------------------------
# The doc generator scans your Angular codebase and extracts:
#   - Components (selector, inputs, outputs, methods, dependencies)
#   - Services (methods with full signatures, JSDoc comments, dependencies)
#   - Modules (declarations, imports, exports, providers)
#   - Routes (paths, components, guards, route data)
#
# Point TARGET_APP_SOURCE to your Angular app's source folder (typically ui/src/app)
# Example: TARGET_APP_SOURCE=C:/rohit/workspace/smart_web-app/ui/src/app
TARGET_APP_SOURCE=
TARGET_APP_NAME=SMART

# Set to true to auto-generate docs from source code AND index them on startup
# When enabled, the server will:
#   1. Scan TARGET_APP_SOURCE for .ts files
#   2. Generate markdown docs in <parent>/docs/auto-generated/
#   3. Index all generated docs into the RAG vector store
AUTO_GENERATE_DOCS=false

# -----------------------------------------------------------------------------
# CORS Origins (allowed frontend URLs)
# -----------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:4200", "http://localhost:3000"]
